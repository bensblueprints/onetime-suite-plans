# UrlVid configuration
PORT=5375
ADMIN_PASSWORD=change-me

# Storage
DB_PATH=./data/urlvid.db
RENDERS_DIR=./data/renders

# Render engine
MAX_CONCURRENT=1          # concurrent renders (raise on beefy servers)
JOB_TIMEOUT_MS=120000     # per-render hard timeout
MAX_FRAMES=1800           # hard cap on fps*duration (OOM guard)

# SSRF hygiene — true lets you capture localhost/LAN targets (handy for self-hosters)
ALLOW_PRIVATE=true

# Binaries (auto-detected if omitted)
# CHROMIUM_PATH=/usr/bin/chromium
# FFMPEG_PATH=/usr/bin/ffmpeg
# PUPPETEER_ARGS=--no-sandbox --disable-dev-shm-usage   # required inside containers
